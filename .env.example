# ====================================================================
# AI Council environment (EXAMPLE). Copy to .env and fill real values.
# NEVER commit .env. Real keys live only here, loaded at run time.
# ====================================================================

# --- App settings (prefix AI_COUNCIL_) ---
AI_COUNCIL_ENV=dev
AI_COUNCIL_CONFIG_PATH=config/default.yaml
AI_COUNCIL_LOG_LEVEL=INFO
AI_COUNCIL_LOG_JSON=true
# Bearer token required on non-health routes in prod (Phase 12).
AI_COUNCIL_API_AUTH_TOKEN=change-me

# --- Per-model endpoints (Target URI + Key, OpenAI-compatible) ---
# For each model in config: <PREFIX>_BASE_URL, <PREFIX>_API_KEY, and
# optional <PREFIX>_MODEL (the deployment/model id the endpoint expects).
# Prefixes must match env_prefix in config/default.yaml.
CLAUDE_OPUS_4_8_BASE_URL=
CLAUDE_OPUS_4_8_API_KEY=
CLAUDE_OPUS_4_8_MODEL=claude-opus-4-8

CLAUDE_SONNET_4_6_BASE_URL=
CLAUDE_SONNET_4_6_API_KEY=
CLAUDE_SONNET_4_6_MODEL=claude-sonnet-4-6

GPT_5_4_BASE_URL=
GPT_5_4_API_KEY=
GPT_5_4_MODEL=gpt-5.4

GPT_5_CODEX_BASE_URL=
GPT_5_CODEX_API_KEY=
GPT_5_CODEX_MODEL=gpt-5-codex

GPT_CHAT_LATEST_BASE_URL=
GPT_CHAT_LATEST_API_KEY=
GPT_CHAT_LATEST_MODEL=gpt-chat-latest

GROK_4_3_BASE_URL=
GROK_4_3_API_KEY=
GROK_4_3_MODEL=grok-4.3

DEEPSEEK_V4_PRO_BASE_URL=
DEEPSEEK_V4_PRO_API_KEY=
DEEPSEEK_V4_PRO_MODEL=DeepSeek-V4-Pro

KIMI_K2_6_BASE_URL=
KIMI_K2_6_API_KEY=
KIMI_K2_6_MODEL=Kimi-K2.6

# --- Infra (Phases 8-10; used by docker compose) ---
DATABASE_URL=postgresql+asyncpg://council:council@localhost:5432/ai_council
REDIS_URL=redis://localhost:6379/0

# --- Observability (Phase 9; optional, off by default) ---
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=
